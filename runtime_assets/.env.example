# TimeTracker runtime configuration
#
# Copy this file to `.env` in the same folder and fill in your real values.
# The macOS installer places this example in:
#   ~/Library/Application Support/TimeTracker/.env.example
#
# Required: Supabase/PostgreSQL connection string
DATABASE_URL=postgresql://postgres:your-password@your-project.pooler.supabase.com:5432/postgres

# Optional: enable file logging for easier troubleshooting
# LOG_TO_FILE=1

# Optional: Sentry settings
# SENTRY_DSN=
# VITE_SENTRY_DSN=
